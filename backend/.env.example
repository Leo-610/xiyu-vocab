# 复制为 backend/.env 后填写（backend/.env 勿提交 Git）

PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# 微信公众平台 → 开发 → 开发设置（与 frontend manifest mp-weixin.appid 一致）
WECHAT_APPID=
WECHAT_APPSECRET=

# 开发环境允许无密码演示登录；生产请用账号密码（前端已默认密码模式）
ALLOW_DEMO_LOGIN=true

# 邮箱验证码登录（可选，配置后优先于账号密码）
# AUTH_RESEND_KEY=re_xxxxxxxx
# AUTH_RESEND_FROM=西语背单词 <notify@yourdomain.com>

# 生产示例：
# NODE_ENV=production
# ALLOW_DEMO_LOGIN=false
# WECHAT_APPID=wxXXXXXXXXXXXXXXXX
# WECHAT_APPSECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
