# 复制为 backend/.env 后填写（backend/.env 勿提交 Git）

PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# 微信公众平台 → 开发 → 开发设置（与 frontend manifest mp-weixin.appid 一致）
WECHAT_APPID=
WECHAT_APPSECRET=

# 开发环境允许 H5 演示登录 POST /api/login；生产环境默认关闭
ALLOW_DEMO_LOGIN=true

# 生产示例：
# NODE_ENV=production
# ALLOW_DEMO_LOGIN=false
# WECHAT_APPID=wxXXXXXXXXXXXXXXXX
# WECHAT_APPSECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
