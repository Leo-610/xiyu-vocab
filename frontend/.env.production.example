# 复制为 .env.production.local 填写真实域名（该文件已被 gitignore）

# 你的生产 API 根路径（含 /api 前缀）
VITE_API_BASE=https://api.yourdomain.com/api

# 构建小程序：
#   cd frontend && npm run build:mp-weixin
# 或临时指定：
#   VITE_API_BASE=https://api.yourdomain.com/api npm run build:mp-weixin

# 微信公众平台 → 开发设置 → 服务器域名 → request 合法域名：
#   https://api.yourdomain.com  （不要带 /api 路径）
